# =============================================================================
# Application Settings
# =============================================================================

# Environment: development | staging | production
APP_ENV=development

# Application name shown in UI and API docs
APP_NAME="My App"

# Base URL of the application (no trailing slash)
APP_BASE_URL=http://localhost:8000

# Debug mode — set to false in production
APP_DEBUG=true

# Secret key for signing JWTs and session tokens
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Allowed CORS origins (comma-separated, or * for all)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Database
# =============================================================================

# SQLite (default for development):
DATABASE_URL=sqlite+aiosqlite:///./myapp.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/myapp

# =============================================================================
# Authentication
# =============================================================================

# JWT algorithm (HS256 recommended; RS256 for asymmetric keys)
JWT_ALGORITHM=HS256

# Bcrypt hashing rounds (12 is a good default; higher = slower but more secure)
BCRYPT_ROUNDS=12

# =============================================================================
# External Auth (optional — Cloudflare / Azure AD header-based SSO)
# =============================================================================

# Enable header-based SSO (e.g. Cloudflare Access or Azure AD App Proxy)
EXTERNAL_AUTH_ENABLED=false

# Header name carrying the verified user email from the proxy
EXTERNAL_AUTH_EMAIL_HEADER=X-Forwarded-Email

# Header name carrying the verified user identity token (optional)
EXTERNAL_AUTH_TOKEN_HEADER=Cf-Access-Jwt-Assertion

# =============================================================================
# Rate Limiting
# =============================================================================

# Default rate limit for API endpoints (slowapi syntax)
# Example: "100/minute", "1000/hour"
RATE_LIMIT_DEFAULT=100/minute

# Stricter limit for authentication endpoints
RATE_LIMIT_AUTH=10/minute

# =============================================================================
# Static Files & Uploads
# =============================================================================

# Directory for serving static files
STATIC_DIR=app/static

# Directory for user-uploaded files
UPLOAD_DIR=uploads

# Maximum upload file size in bytes (default: 10 MB)
MAX_UPLOAD_SIZE=10485760

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file path (leave blank to log to stdout only)
LOG_FILE=

# =============================================================================
# Email (optional — for password reset, notifications)
# =============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# =============================================================================
# Multi-Tenancy
# =============================================================================

# Default tenant slug created on first run
DEFAULT_TENANT=default

# Allow public tenant self-registration
ALLOW_TENANT_REGISTRATION=false

# =============================================================================
# Dev Bypass (NEVER set in production)
# =============================================================================

# Token that allows headless Chrome / Claude Code to access the app without
# authenticating. Pass as ?_dev_token=<value> query param or X-Dev-Token header.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to disable.
DEV_BYPASS_TOKEN=

# =============================================================================
# Celery / Background Tasks (optional)
# =============================================================================

# Broker URL for Celery workers
CELERY_BROKER_URL=redis://localhost:6379/0

# Result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/1
